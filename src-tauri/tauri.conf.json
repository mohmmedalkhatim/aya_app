{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/aya_app.ico"
    ],
    "resources": {
      "resources/medicine_roi_int8.tflite": "resources/",
      "resources/tessdata/eng.traineddata": "resources/tessdata/"
    }
  },
  "productName": "aya_app",
  "mainBinaryName": "aya_app",
  "version": "0.4.0",
  "identifier": "com.aya.app",
  "plugins": {},
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "com.aya.app",
        "width": 460,
        "height": 600,
        "maxWidth": 460
      }
    ]
  }
}